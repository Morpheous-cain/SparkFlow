rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SPARKFLOW OPS - SECURITY RULES CONFIGURATION
     * 
     * Core Philosophy:
     * This ruleset enforces a multi-tiered authorization model designed for high-efficiency car wash operations. 
     * It prioritizes explicit ownership and role-based access while maintaining flexibility for rapid 
     * prototyping by not enforcing strict data schemas outside of relational integrity.
     * 
     * Data Structure:
     * The system utilizes a flat top-level collection architecture for most entities (Bays, Services, Staff, 
     * Inventory, Vehicles, Transactions) to simplify querying, with a hierarchical structure for 
     * customer-specific sub-resources like Badges.
     * 
     * Key Security Decisions:
     * 1. Role-Based Access Control (RBAC): Access for Staff, Agents, and Managers is determined by 
     *    the existence of documents in dedicated /roles_ collections.
     * 2. Authorization Independence: Critical fields like 'customerId', 'assignedAttendantId', and 
     *    'assignedStaffId' are denormalized onto documents (Vehicles, Transactions, Logistics) to 
     *    allow for fast, single-document security checks without parent-lookups.
     * 3. Prototyping Flexibility: Rules do not validate general content fields (e.g., strings vs. numbers), 
     *    focusing only on verifying the identity of the requester and the integrity of ownership links.
     * 4. Secure Defaults: All write operations require authenticated authorization. Public access is 
     *    limited strictly to the Service catalog.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Checks
    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_managers/$(request.auth.uid));
    }

    function isAgent() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_agents/$(request.auth.uid));
    }

    function isAttendant() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_attendants/$(request.auth.uid));
    }

    function isAnyStaff() {
      return isManager() || isAgent() || isAttendant();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Operational status of car wash bays. Restricted to Managers.
     * @path /bays/{bayId}
     * @allow Managers to (list) all bays.
     * @deny Unauthenticated users from (get)ing bay status.
     * @principle Role-based access for operational infrastructure.
     */
    match /bays/{bayId} {
      allow get, list: if isManager() || isAnyStaff();
      allow create, update, delete: if isManager();
    }

    /**
     * @description Product catalog including pricing and duration. Publicly visible.
     * @path /services/{serviceId}
     * @allow Any user (including anonymous) to (list) services.
     * @deny Non-managers from (update)ing service prices.
     * @principle Publicly readable configuration with restricted administrative writes.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isManager();
    }

    /**
     * @description Staff profile management. Staff can see their own info; Managers have full control.
     * @path /staff/{staffId}
     * @allow A staff member to (get) their own profile.
     * @deny A staff member from (update)ing their own performance metrics or pay.
     * @principle Self-viewing for employees, administrative control for management.
     */
    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isManager();
      allow list: if isManager();
      allow create, update, delete: if isManager();
    }

    /**
     * @description Consumable item tracking. Manager only access.
     * @path /inventory_items/{inventoryItemId}
     * @allow Managers to (update) stock counts.
     * @deny Regular staff or customers from (list)ing wholesale prices.
     * @principle Restricted administrative access to internal logistics.
     */
    match /inventory_items/{inventoryItemId} {
      allow get, list, create, update, delete: if isManager();
    }

    /**
     * @description Customer CRM profiles. Supports self-service and agent-assisted registration.
     * @path /customers/{customerId}
     * @allow Customers to (update) their own profile info.
     * @deny Customers from (delete)ing their own profiles.
     * @principle Ownership-based access for PII, with Agent/Manager overrides for support.
     */
    match /customers/{customerId} {
      allow get: if isOwner(customerId) || isAnyStaff();
      allow list: if isAnyStaff();
      allow create: if isOwner(customerId) || isAgent() || isManager();
      allow update: if (resource != null && isOwner(customerId)) || isManager();
      allow delete: if isManager();
    }

    /**
     * @description Gamification rewards for customers.
     * @path /customers/{customerId}/badges/{customerBadgeId}
     * @allow Customers to (list) their earned badges.
     * @deny Customers from (create)ing their own badges.
     * @principle Ownership-based reads with system-only (Manager role) writes.
     */
    match /customers/{customerId}/badges/{customerBadgeId} {
      allow get, list: if isOwner(customerId) || isManager();
      allow create, update, delete: if isManager();
    }

    /**
     * @description Real-time car wash workflow management.
     * @path /vehicles_live/{vehicleId}
     * @allow Customers to (get) the status of their own vehicle via 'customerId'.
     * @deny Attendants from (update)ing vehicles they are not assigned to.
     * @principle Denormalized ownership/assignment fields enable secure tracking.
     */
    match /vehicles_live/{vehicleId} {
      allow get: if isManager() || isAttendant() || (resource != null && resource.data.customerId == request.auth.uid);
      allow list: if isManager() || isAttendant() || (isSignedIn() && request.query.limit <= 100); // List filtered by client query usually
      allow create: if isManager() || isAgent();
      allow update: if isManager() || (resource != null && resource.data.assignedAttendantId == request.auth.uid);
      allow delete: if isManager();
    }

    /**
     * @description Financial records for car wash services.
     * @path /transactions/{transactionId}
     * @allow Customers to (list) their own transaction history.
     * @deny Customers from (create)ing or (update)ing transactions.
     * @principle Ownership-based reads for financial transparency; Manager-only writes.
     */
    match /transactions/{transactionId} {
      allow get, list: if isManager() || (resource != null && resource.data.customerId == request.auth.uid);
      allow create, update, delete: if isManager();
    }

    /**
     * @description Pickup and delivery requests (e.g., carpets).
     * @path /logistics_requests/{logisticsRequestId}
     * @allow Customers to (create) a request linked to their UID.
     * @deny Assigned staff from (delete)ing the request.
     * @principle Tri-party access: Customer (owner), Assigned Staff (worker), and Manager (admin).
     */
    match /logistics_requests/{logisticsRequestId} {
      allow get, list: if isManager() || (resource != null && (resource.data.customerId == request.auth.uid || resource.data.assignedStaffId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isManager() || (resource != null && (resource.data.customerId == request.auth.uid || resource.data.assignedStaffId == request.auth.uid));
      allow delete: if isManager();
    }

    /**
     * @description Role assignment collections.
     * @path /roles_agents/{agentId}, /roles_attendants/{attendantId}, /roles_managers/{managerId}
     * @allow Managers to (list) roles.
     * @deny Any user from (create)ing their own role document.
     * @principle Strict administrative control over authorization levels.
     */
    match /roles_agents/{agentId} {
      allow get, list: if isAnyStaff();
      allow create, update, delete: if isManager();
    }
    match /roles_attendants/{attendantId} {
      allow get, list: if isAnyStaff();
      allow create, update, delete: if isManager();
    }
    match /roles_managers/{managerId} {
      allow get, list: if isManager();
      allow create, update, delete: if isManager();
    }
  }
}